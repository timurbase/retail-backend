# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=dev-secret-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgres://retailflow:retailflow@localhost:5432/retailflow

# Redis (cache + Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
JWT_ACCESS_LIFETIME_MIN=30
JWT_REFRESH_LIFETIME_DAYS=14

# SMS (Eskiz.uz)
SMS_PROVIDER=console
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=10

# OpenAI
OPENAI_API_KEY=
OPENAI_DEMO_MODE=true

# Cloudflare R2
R2_BUCKET=
R2_ENDPOINT=
R2_KEY=
R2_SECRET=

# Soliq.uz (STIR + MXIK)
SOLIQ_API_BASE=https://api.soliq.uz
SOLIQ_API_TOKEN=

# Didox
DIDOX_WEBHOOK_SECRET=

# Frontend (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Sentry
SENTRY_DSN=
